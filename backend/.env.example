# ─────────────────────────────────────────
#  SERVER ENVIRONMENT — EXAMPLE FILE
#  Copy this to .env and fill in your values
# ─────────────────────────────────────────

# ── App ──────────────────────────────────
PORT=4000
FRONTEND_URL=http://localhost:5173

# ── Database (Supabase PostgreSQL) ────────
# Connection pooler – used at runtime (port 6543)
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection – used for Prisma migrations (port 5432)
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres"

# ── Authentication ────────────────────────
JWT_SECRET_KEY=your_jwt_secret_here
JWT_EXPIRE=3d
COOKIE_EXPIRE=3

# ── Email (SMTP) ──────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_SERVICE=gmail
SMTP_PORT=465
SMTP_MAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# ── Cloudinary ────────────────────────────
CLOUDINARY_CLIENT_NAME=your_cloud_name
CLOUDINARY_CLIENT_API=your_api_key
CLOUDINARY_CLIENT_SECRET=your_api_secret
